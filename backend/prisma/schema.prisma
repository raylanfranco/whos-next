generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────

enum MerchantPlan {
  FREE
  PRO
  GRANDFATHERED
}

enum MerchantVertical {
  GENERIC
  AUTOMOTIVE
  TATTOO
  BEAUTY
}

// ── Merchant ──────────────────────────────────────────────

model Merchant {
  id               String   @id @default(cuid())
  name             String
  timezone         String   @default("America/New_York")
  shopHours        Json?    @map("shop_hours_json") // { mon: { open: "09:00", close: "18:00" }, ... }
  settings         Json?    @map("settings_json")

  // Plan & vertical
  plan             MerchantPlan     @default(FREE)
  planActivatedAt  DateTime?        @map("plan_activated_at")
  stripeSubscriptionId String?      @map("stripe_subscription_id")
  vertical         MerchantVertical @default(GENERIC)

  // Direct auth (email/password) — used in this Clover-decoupled fork
  email            String?  @unique
  passwordHash     String?  @map("password_hash")

  // Clover OAuth (optional — kept for backward compat with original BayReady)
  cloverMerchantId String?  @unique @map("clover_merchant_id")
  cloverAccessToken  String? @map("clover_access_token")
  cloverRefreshToken String? @map("clover_refresh_token")
  cloverTokenExpiry  DateTime? @map("clover_token_expiry")

  // Stripe Connect (Standard)
  stripeAccountId      String?   @unique @map("stripe_account_id")   // acct_xxxx from OAuth
  stripeAccessToken    String?   @map("stripe_access_token")          // OAuth access token (deprecated but functional)
  stripePublishableKey String?   @map("stripe_publishable_key")       // pk_xxxx for frontend Elements
  stripeConnected      Boolean   @default(false) @map("stripe_connected")
  stripeConnectedAt    DateTime? @map("stripe_connected_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  services           Service[]
  customers          Customer[]
  bookings           Booking[]
  availabilityRules  AvailabilityRule[]
  blockedDates       BlockedDate[]
  pushSubscriptions  PushSubscription[]

  @@map("merchants")
}

// ── Service ───────────────────────────────────────────────

model Service {
  id            String  @id @default(cuid())
  merchantId    String  @map("merchant_id")
  cloverItemId  String? @map("clover_item_id")
  name          String
  description   String?
  category      String?
  imageUrl      String?  @map("image_url")
  durationMins  Int     @map("duration_mins")
  priceCents    Int     @map("price_cents")
  isActive      Boolean @default(true) @map("is_active")

  // Manual parts mappings: { "2019_Honda_Civic_EX": ["Metra 99-7812B", "Axxess AX-HD002"] }
  partsMappings Json? @map("parts_mappings_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant        Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  intakeQuestions IntakeQuestion[]

  @@map("services")
}

// ── Customer ──────────────────────────────────────────────

model Customer {
  id                String  @id @default(cuid())
  merchantId        String  @map("merchant_id")
  cloverCustomerId  String? @map("clover_customer_id")
  name              String
  email             String?
  phone             String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]
  bookings Booking[]

  @@unique([merchantId, email])
  @@unique([merchantId, cloverCustomerId])
  @@map("customers")
}

// ── Vehicle ───────────────────────────────────────────────

model Vehicle {
  id         String  @id @default(cuid())
  customerId String  @map("customer_id")
  year       Int?
  make       String?
  model      String?
  trim       String?
  notes      String?
  photos     Json?   @map("photos_json") // ["https://s3.../photo1.jpg", ...]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("vehicles")
}

// ── Booking ───────────────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  WAITING_ON_PARTS
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PartStatus {
  NEEDED
  ORDERED
  RECEIVED
}

model Booking {
  id            String        @id @default(cuid())
  merchantId    String        @map("merchant_id")
  serviceId     String        @map("service_id")
  customerId    String        @map("customer_id")
  vehicleId     String?       @map("vehicle_id")
  startsAt      DateTime      @map("starts_at")
  endsAt        DateTime      @map("ends_at")
  status        BookingStatus @default(PENDING)
  isWalkIn           Boolean       @default(false) @map("is_walk_in")
  cloverOrderId      String?       @map("clover_order_id")
  intakeData         Json?         @map("intake_data_json")
  notes              String?
  depositAmountCents Int?          @map("deposit_amount_cents")
  depositPaidAt      DateTime?     @map("deposit_paid_at")
  cloverChargeId     String?       @map("clover_charge_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchant Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  service  Service       @relation(fields: [serviceId], references: [id])
  customer Customer      @relation(fields: [customerId], references: [id])
  vehicle  Vehicle?      @relation(fields: [vehicleId], references: [id])
  parts    BookingPart[]

  @@index([merchantId, startsAt])
  @@index([merchantId, status])
  @@map("bookings")
}

// ── Booking Parts ────────────────────────────────────────

model BookingPart {
  id         String     @id @default(cuid())
  bookingId  String     @map("booking_id")
  partName   String     @map("part_name")
  partNumber String?    @map("part_number")
  status     PartStatus @default(NEEDED)
  notes      String?
  orderedAt  DateTime?  @map("ordered_at")
  receivedAt DateTime?  @map("received_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_parts")
}

// ── Availability ──────────────────────────────────────────

model AvailabilityRule {
  id         String  @id @default(cuid())
  merchantId String  @map("merchant_id")
  dayOfWeek  Int     @map("day_of_week") // 0 = Sunday, 6 = Saturday
  startTime  String  @map("start_time")  // "09:00"
  endTime    String  @map("end_time")    // "18:00"
  isBlocked  Boolean @default(false) @map("is_blocked")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, dayOfWeek])
  @@map("availability_rules")
}

model BlockedDate {
  id         String   @id @default(cuid())
  merchantId String   @map("merchant_id")
  date       DateTime @db.Date
  reason     String?

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, date])
  @@map("blocked_dates")
}

// ── Intake Questions ─────────────────────────────────────

enum QuestionType {
  RADIO
  CHECKBOX
  TEXT
  SELECT
  TINT_ZONE
  PHOTO_UPLOAD
  BODY_MAP
}

model IntakeQuestion {
  id        String       @id @default(cuid())
  serviceId String       @map("service_id")
  question  String
  type      QuestionType
  options   Json?        // For RADIO/CHECKBOX/SELECT: ["Option A", "Option B", ...]
  required  Boolean      @default(false)
  sortOrder Int          @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("intake_questions")
}

// ── Push Subscriptions ───────────────────────────────────

model PushSubscription {
  id          String   @id @default(cuid())
  merchantId  String   @map("merchant_id")
  endpoint    String
  p256dh      String
  auth        String
  deviceLabel String?  @map("device_label")
  createdAt   DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, endpoint])
  @@map("push_subscriptions")
}

// ── Fitment Database ─────────────────────────────────────

model FitmentEntry {
  id         String  @id @default(cuid())
  year       Int
  make       String
  model      String
  trim       String?
  category   String                    // "dash-kit", "wire-harness", "speaker-front", etc.
  partNumber String  @map("part_number")
  partName   String  @map("part_name")
  brand      String?
  notes      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([year, make, model])
  @@index([category])
  @@map("fitment_entries")
}

// ── Adapter Records ──────────────────────────────────

model AdapterRecord {
  id          String  @id @default(cuid())
  bookingId   String? @map("booking_id")
  customerId  String? @map("customer_id")
  adapterType String  @map("adapter_type")
  data        Json    @map("data_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([bookingId])
  @@index([customerId])
  @@map("adapter_records")
}
