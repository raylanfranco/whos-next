# ═══════════════════════════════════════════════════════════
# Who's Next? — Backend Environment Variables
# Copy to .env and fill in values before running
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/whosnext

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret

# ── Frontend URL (comma-separated for multiple origins) ───
FRONTEND_URL=http://localhost:5173

# ── Stripe Connect (merchant payments) ────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_CLIENT_ID=ca_...
STRIPE_REDIRECT_URI=http://localhost:3001/stripe/connect/callback
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Billing (Pro subscriptions) ────────────────────
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...

# ── Web Push (VAPID) ─────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:ray@victoryrush.dev

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_...

# ── SMS (Twilio) — optional ──────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── File Uploads (S3-compatible) — optional for V1 ───────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Clover OAuth (DEPRECATED — kept for backward compat) ─
# CLOVER_APP_ID=
# CLOVER_APP_SECRET=
# CLOVER_API_BASE_URL=https://sandbox.dev.clover.com
