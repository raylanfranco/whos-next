# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bayready

# Auth (required for this fork)
JWT_SECRET=change-me-to-a-random-secret

# Stripe (replaces Clover payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Clover OAuth (DEPRECATED — kept for backward compat, not required in this fork)
# CLOVER_APP_ID=
# CLOVER_APP_SECRET=
# CLOVER_API_BASE_URL=https://sandbox.dev.clover.com

# Email
RESEND_API_KEY=

# File uploads (S3-compatible) — optional for V1
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
